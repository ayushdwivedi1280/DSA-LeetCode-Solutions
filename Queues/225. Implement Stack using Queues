/*
-------------------------------------------------------
Implement Stack using Queues
LeetCode: 225. Implement Stack using Queues
-------------------------------------------------------

Idea:
A stack follows LIFO (Last In First Out).
A queue follows FIFO (First In First Out).

To simulate stack behavior using queues, we maintain
the newest element always at the front of q1.

Approach:
1. Use two queues: q1 and q2.
2. During push:
   - Move all elements from q1 to q2.
   - Push the new element into q1.
   - Move all elements back from q2 to q1.

   This ensures the newest element is always at the
   front of q1 (like the top of a stack).

3. Pop:
   - Simply remove the front element from q1.

4. Top:
   - Return the front element of q1.

5. Empty:
   - Check if q1 is empty.

Time Complexity:
push()  -> O(n)
pop()   -> O(1)
top()   -> O(1)
empty() -> O(1)

Space Complexity:
O(n)

-------------------------------------------------------
*/

class MyStack {
public:

    queue<int> q1;
    queue<int> q2;

    MyStack() {
        
    }

    void push(int x) {

        // Move all elements from q1 to q2
        while(!q1.empty()){
            q2.push(q1.front());
            q1.pop();
        }

        // Insert new element into q1
        q1.push(x);

        // Move everything back to q1
        while(!q2.empty()){
            q1.push(q2.front());
            q2.pop();
        }
    }
    
    int pop() {
        int ans = q1.front();
        q1.pop();
        return ans;
    }
    
    int top() {
        return q1.front();
    }

    bool empty(){ 
        return q1.empty();
    }
};

/*
Usage:
MyStack* obj = new MyStack();
obj->push(x);
int param_2 = obj->pop();
int param_3 = obj->top();
bool param_4 = obj->empty();
*/
