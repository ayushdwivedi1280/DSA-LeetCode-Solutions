/*
===========================================================
🔹 Problem: 155. Min Stack
🔹 Platform: LeetCode
🔹 Difficulty: Medium
🔹 Topic: Stack

-----------------------------------------------------------
🔹 Problem Statement:
Design a stack that supports push, pop, top, 
and retrieving the minimum element in constant time.

Implement the MinStack class:
- push(int val)
- pop()
- top()
- getMin()

-----------------------------------------------------------
🔹 Approach:
Use stack<pair<int,int>> to store:
{value, minimum_till_now}

At every push:
minValue = min(currentValue, previousMinimum)

This ensures getMin() works in O(1).

-----------------------------------------------------------
🔹 Time Complexity:
push()   → O(1)
pop()    → O(1)
top()    → O(1)
getMin() → O(1)

-----------------------------------------------------------
🔹 Space Complexity:
O(n)

-----------------------------------------------------------
🔹 Key Concept:
Store the minimum value along with each element 
to avoid using extra traversal.

===========================================================
*/



class MinStack {
public:
stack<pair<int,int>> st;
    MinStack() {
        
    }
    
    void push(int val) {
        
        if(st.empty()){
           st.push({val,val});
        }
        else if(st.top().second<val){
            int minVal = st.top().second;
            st.push({val,minVal});
        }
        else{
            st.push({val,val});
        } 
    }
    void pop() {
        st.pop();
    }
    int top() {
        return st.top().first; 
    }
    int getMin() {
        return st.top().second;
    }
};

