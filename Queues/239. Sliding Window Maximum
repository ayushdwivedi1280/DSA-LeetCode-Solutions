/*
---------------------------------------------------------------
Author  : Ayush Dwivedi
Problem : Sliding Window Maximum
Platform: LeetCode (Hard)

Description:
Given an integer array `nums` and a window size `k`, the task is 
to find the maximum element in every sliding window of size `k`.

Approach:
This solution uses a deque to store indices of useful elements 
for the current window.

Key Idea:
1. The deque stores indices in decreasing order of their values.
2. The front of the deque always contains the index of the 
   maximum element for the current window.
3. Remove indices that fall outside the window.
4. Remove smaller elements from the back before inserting 
   a new element.

Time Complexity  : O(n)
Space Complexity : O(k)
---------------------------------------------------------------
*/

class Solution {
public:
    vector<int> maxSlidingWindow(vector<int>& nums, int k) {
        deque<int> dq;
        vector<int> ans;

        // Process first window
        for(int i=0;i<k;i++){
            while(!dq.empty() && nums[dq.back()]<=nums[i]){
                dq.pop_back();
            }
            dq.push_back(i);
        }

        // Process remaining elements
        for(int i=k;i<nums.size();i++){

            ans.push_back(nums[dq.front()]);

            // Remove elements out of this window
            while(!dq.empty() && dq.front()<=i-k){
                dq.pop_front();
            }

            // Remove smaller elements from back
            while(!dq.empty() && nums[dq.back()]<=nums[i]){
                dq.pop_back();
            }

            dq.push_back(i);
        }

        // Maximum of last window
        ans.push_back(nums[dq.front()]);

        return ans;
    }
};
