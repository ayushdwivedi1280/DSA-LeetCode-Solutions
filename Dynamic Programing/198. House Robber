/*
    Problem: House Robber (LeetCode 198)

    Approach:
    This problem follows the Dynamic Programming "take or skip" pattern.

    At every house we have two choices:
    1. Rob the current house
       -> money = current house value + profit from house i-2
    2. Skip the current house
       -> money = profit from house i-1

    We take the maximum of these two choices.

    Instead of using a DP array, we optimize space by keeping only two variables:
    prev1 = maximum money we can rob till previous house
    prev2 = maximum money we can rob till house before previous

    Time Complexity: O(n)
    Space Complexity: O(1)
*/

class Solution {
public:
    int rob(vector<int>& nums) {

        int prev1 = 0;
        int prev2 = 0;

        for(int num : nums){
            int temp = max(prev1, prev2 + num);
            prev2 = prev1;
            prev1 = temp;
        }

        return prev1;
    }
};
