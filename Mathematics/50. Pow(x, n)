/*
------------------------------------------------------
🧠 Problem: Pow(x, n)  (LeetCode 50)

📌 Approach:
- Use Binary Exponentiation (Fast Power)
- Reduce time complexity from O(n) → O(log n)

📌 Key Ideas:
- If n is negative → convert x = 1/x and n = -n
- If n is odd → multiply result with current x
- Square x in each step (x = x * x)
- Divide n by 2 each time

📌 Edge Cases:
- n == 0 → return 1
- x == 0 → return 0
- x == 1 → return 1
- x == -1 → depends on parity of n

📌 Time Complexity: O(log n)
📌 Space Complexity: O(1)

------------------------------------------------------
*/

class Solution {
public:
    double myPow(double x, int n) {
        if(n==0) return 1.0;
        if(x==0) return 0.0;
        if(x==1) return 1.0;
        if(x==-1 && n%2==0) return 1.0;
        if(x==-1 && n%2!=0) return -1.0;

        long binForm = n;

        if(n<0){
            x = 1/x;
            binForm = -binForm;
        }

        double ans = 1;

        while(binForm > 0){
            if(binForm % 2 == 1){
                ans *= x;
            }
            x *= x;
            binForm /= 2;
        }

        return ans;
    }
};
