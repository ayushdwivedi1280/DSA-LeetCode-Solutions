/*
    Problem: Majority Element
    Platform: LeetCode

    Approach: Boyer–Moore Voting Algorithm

    Description:
    The majority element is the element that appears more than ⌊n/2⌋ times 
    in the array. This algorithm finds the majority element in linear time 
    and constant space.

    Logic:
    - Maintain two variables:
        1. ans  -> candidate for majority element
        2. freq -> counter

    - Traverse the array:
        • If freq becomes 0, choose the current element as the new candidate.
        • If the current element equals the candidate, increase freq.
        • Otherwise decrease freq.

    - Because the majority element appears more than n/2 times, it will remain
      as the final candidate.

    Time Complexity: O(n)
    Space Complexity: O(1)
*/

class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int freq = 0; 
        int ans = 0;

        for(int i = 0; i < nums.size(); i++) {
            if(freq == 0) {
                ans = nums[i];
            }

            if(nums[i] == ans) {
                freq++;
            } 
            else {
                freq--;
            }
        }

        return ans;
    }
};
