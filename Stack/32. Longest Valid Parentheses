/*
    Problem: Longest Valid Parentheses
    Platform: LeetCode
    Approach: Stack

    Idea:
    - We use a stack to store indices of parentheses.
    - First we push -1 into the stack to act as a base index.
    - Traverse the string:
        1. If we encounter '(', push its index into the stack.
        2. If we encounter ')', pop the stack.
    - If the stack becomes empty after popping, push the current index.
      This acts as a new base for future valid substrings.
    - Otherwise, calculate the length of the valid substring using:
            current_index - stack.top()
      and update maxLen.

    Time Complexity: O(n)
    Space Complexity: O(n)

    Author: Ayush Dwivedi
*/




class Solution {
public:
    int longestValidParentheses(string s) {
        
        if(s.empty()) return 0;

        stack<int> st;
        st.push(-1);
        int maxLen=0;

        for(int i=0;i<s.size();i++){
            if(s[i]=='('){
                st.push(i);
            }
            else{
                st.pop();
                if(st.size()==0){
                    st.push(i);
                }
                else{
                    maxLen = max(maxLen,(i-st.top()));
                }
            }
        }
        return maxLen;
    
    }
};
