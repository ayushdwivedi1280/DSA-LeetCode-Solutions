// Problem: LeetCode 84 - Largest Rectangle in Histogram
// Difficulty: Hard
// Approach: Monotonic Stack (Next Smaller to Right + Previous Smaller to Left)
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <vector>
#include <stack>
#include <algorithm>
using namespace std;

class Solution {
public:
    int largestRectangleArea(vector<int>& heights) {
        stack<int> st;
        int n = heights.size();

        vector<int> right(n);  // Stores index of next smaller element to the right
        vector<int> left(n);   // Stores index of previous smaller element to the left

        // Step 1: Find Next Smaller Element to Right
        for(int i = n - 1; i >= 0; i--) {
            while(!st.empty() && heights[st.top()] >= heights[i]) {
                st.pop();
            }
            right[i] = st.empty() ? n : st.top();
            st.push(i);
        }

        // Clear stack before reusing
        while(!st.empty()) {
            st.pop();
        }

        // Step 2: Find Previous Smaller Element to Left
        for(int i = 0; i < n; i++) {
            while(!st.empty() && heights[st.top()] >= heights[i]) {
                st.pop();
            }
            left[i] = st.empty() ? -1 : st.top();
            st.push(i);
        }

        // Step 3: Calculate Maximum Area
        int ans = 0;
        for(int i = 0; i < n; i++) {
            int width = right[i] - left[i] - 1;
            int currentArea = heights[i] * width;
            ans = max(ans, currentArea);
        }

        return ans;
    }
};
