/*
    Problem: Product of Array Except Self
    Platform: LeetCode

    Approach:
    - We calculate the result using prefix and suffix products.
    - First pass (left to right):
        -> ans[i] stores product of all elements before index i.
    - Second pass (right to left):
        -> Maintain a suffix product and multiply it with ans[i].

    Key Idea:
    - Avoid using division.
    - Use O(1) extra space (excluding output array).

    Time Complexity: O(n)
    Space Complexity: O(1)

    Example:
    Input:  [1,2,3,4]
    Output: [24,12,8,6]
*/

class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
       int n = nums.size();

       // Initialize result array with 1
       vector<int> ans(n, 1);

       // Step 1: Prefix product
       for(int i = 1; i < n; i++){
           ans[i] = ans[i-1] * nums[i-1]; 
       }

       // Step 2: Suffix product
       int suffix = 1;
       for(int i = n-2; i >= 0; i--){
           suffix *= nums[i+1];
           ans[i] *= suffix;
       }

       return ans;
    }
};
